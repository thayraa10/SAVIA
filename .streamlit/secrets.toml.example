# ──────────────────────────────────────────────────────────────────────────────
# SAVIA — Plantilla de configuración de secretos
# ──────────────────────────────────────────────────────────────────────────────
# INSTRUCCIONES:
#   1. Copia este archivo como  .streamlit/secrets.toml
#   2. Rellena el token con tu Personal Access Token de GitHub
#   3. NUNCA subas secrets.toml a GitHub (ya está en .gitignore)
#   4. En Streamlit Cloud: ve a Settings → Secrets y pega el contenido
# ──────────────────────────────────────────────────────────────────────────────

# ── GitHub Personal Access Token ──────────────────────────────────────────────
# Cómo obtenerlo (2 minutos, completamente gratis):
#   1. Ve a https://github.com/settings/tokens
#   2. Haz clic en "Generate new token (classic)"
#   3. Ponle un nombre: "SAVIA persistencia"
#   4. Expiration: No expiration (o la que prefieras)
#   5. Selecciona el scope: ✅ gist
#   6. Haz clic en "Generate token"
#   7. Copia el token (empieza con ghp_...)

[github]
token = "ghp_TU_TOKEN_AQUI"
