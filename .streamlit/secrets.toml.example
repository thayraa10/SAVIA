# ──────────────────────────────────────────────────────────────────────────────
# SAVIA — Plantilla de configuración de secretos
# ──────────────────────────────────────────────────────────────────────────────
# INSTRUCCIONES:
#   1. Copia este archivo como  .streamlit/secrets.toml
#   2. Rellena los valores con tus credenciales reales
#   3. NUNCA subas secrets.toml a GitHub (ya está en .gitignore)
#   4. En Streamlit Cloud: pega el contenido en Settings → Secrets
# ──────────────────────────────────────────────────────────────────────────────

# ── Google Cloud Service Account ──────────────────────────────────────────────
# Crea una Service Account en https://console.cloud.google.com/
# Habilita la API de Google Drive para el proyecto
# Descarga la clave JSON y pega los campos aquí:

[gcp_service_account]
type                        = "service_account"
project_id                  = "TU_PROJECT_ID"
private_key_id              = "TU_PRIVATE_KEY_ID"
private_key                 = "-----BEGIN RSA PRIVATE KEY-----\nTU_CLAVE_PRIVADA\n-----END RSA PRIVATE KEY-----\n"
client_email                = "savia@TU_PROJECT_ID.iam.gserviceaccount.com"
client_id                   = "TU_CLIENT_ID"
auth_uri                    = "https://accounts.google.com/o/oauth2/auth"
token_uri                   = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url        = "https://www.googleapis.com/robot/v1/metadata/x509/savia%40TU_PROJECT_ID.iam.gserviceaccount.com"

# ── Google Drive ───────────────────────────────────────────────────────────────
# Crea una carpeta en Google Drive
# Comparte esa carpeta con el email de la Service Account (con permisos de Editor)
# Copia el ID de la carpeta (la parte final de la URL de Drive)
# Ejemplo URL: https://drive.google.com/drive/folders/1aBcDeFgHiJkLmNoPqRsTuVwXyZ
#                                                       ↑ este es el folder_id

[google_drive]
folder_id = "TU_FOLDER_ID_DE_GOOGLE_DRIVE"
